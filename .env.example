# ── Google Cloud / Vertex AI ────────────────────────────────────────────────
# Your GCP project ID (required).
GOOGLE_CLOUD_PROJECT=your-project-id

# GCP region for Vertex AI. Defaults to us-central1 if not set.
GOOGLE_CLOUD_REGION=us-central1

# Option A — local dev: path to a service-account key JSON file.
# NEVER commit this file. It is in .gitignore.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-key.json

# Option B — Vercel/production: the entire service-account JSON as a single
# minified line. Paste the output of: cat gcp-key.json | jq -c
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":...}

# ── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Required only for rate limiting. When unset the app runs without rate limits
# — acceptable for local dev, NOT acceptable in production (open CORS endpoint).
# Get these from https://console.upstash.com after creating a Redis database.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Public runtime config ───────────────────────────────────────────────────
# The public base URL of this deployment. Used to generate the embed snippet
# shown on the landing page. Must NOT end with a slash.
# Example: https://example.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
